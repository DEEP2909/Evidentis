# ============================================================
# EvidentIS India Environment Configuration
# Copy to .env and fill in values
# ============================================================

# ---- Node.js API ----
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Auth - RS256 JWT Keys
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
JWT_ISSUER=evidentis-india
JWT_AUDIENCE=evidentis-india-api
APP_ENCRYPTION_KEY=

# Database
DATABASE_URL=postgresql://evidentis:evidentis_dev_password@localhost:5432/evidentis
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_SSL=false
DB_SSL_CA=
SEED_DEMO_DATA=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_DB_QUEUE=0
REDIS_DB_CACHE=3

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
S3_REGION=centralindia
S3_BUCKET=evidentis-india-documents
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false

# AI Service
AI_SERVICE_URL=http://localhost:5000
AI_SERVICE_TIMEOUT_MS=60000
AI_SERVICE_INTERNAL_KEY=

# Malware Scanner
MALWARE_SCANNER=clamav
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Email
EMAIL_DELIVERY_MODE=log
MAIL_FROM=noreply@evidentis.tech
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# India Billing and Integrations
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
INDIANKANOON_API_KEY=
INDIANKANOON_BASE_URL=https://api.indiankanoon.org
ECOURTS_API_KEY=
ECOURTS_BASE_URL=https://services.ecourts.gov.in
MSG91_AUTH_KEY=
MSG91_SENDER_ID=EVDTIS
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_BASE_URL=https://control.msg91.com/api
OTP_EXPIRY_MINUTES=10

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=evidentis-india-api

# OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Frontend and security
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_MINUTES=15
RATE_LIMIT_OTP_REQUESTS=6
RATE_LIMIT_OTP_WINDOW_MINUTES=15
RATE_LIMIT_UPLOAD_REQUESTS=20
RATE_LIMIT_UPLOAD_WINDOW_MINUTES=60
RATE_LIMIT_RESEARCH_REQUESTS=120
RATE_LIMIT_RESEARCH_WINDOW_MINUTES=60
RATE_LIMIT_GENERAL_REQUESTS=1000
RATE_LIMIT_GENERAL_WINDOW_MINUTES=60
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
MAX_FILE_SIZE_BYTES=52428800
MAX_BATCH_SIZE_BYTES=209715200

# India compliance defaults
DATA_PROTECTION_OFFICER_EMAIL=dpo@evidentis.tech
DPDP_CONSENT_VERSION=1.0
DATA_RESIDENCY_REGION=centralindia
DEFAULT_LANGUAGE=hi
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata
GST_RATE=18
FIRM_GSTIN=

# WebAuthn
WEBAUTHN_RP_NAME=EvidentIS India
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ---- Python AI Service ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_EXTRACT=mistral:7b-instruct-q4_K_M
OLLAMA_MODEL_RESEARCH=mistral:7b-instruct-q4_K_M
OLLAMA_TIMEOUT=120
EMBEDDING_MODEL=sentence-transformers/LaBSE
EMBEDDING_DIM=768
EXTRACT_MODEL=ai4bharat/indic-bert
TRANSLATION_MODEL=ai4bharat/indictrans2-en-indic-1B
OCR_ENGINES=tesseract
OCR_LANGUAGES=eng+hin+ben+tam+tel+kan+mal+mar+guj+pan+ori+asm+urd
GOOGLE_VISION_ENABLED=false
GPU_ENABLED=false
MODEL_CACHE_DIR=./models
CLAUSE_EXTRACTION_THRESHOLD=0.82
RESEARCH_CACHE_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS_PER_MINUTE=120
# Must match API-side AI_SERVICE_INTERNAL_KEY when internal auth is enabled
AI_SERVICE_INTERNAL_KEY=

# ---- Next.js Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
