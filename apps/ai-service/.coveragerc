[run]
omit =
    tests/*
    models/loader.py
    evaluation/*
    config.py
    apps/ai-service/tests/*
    apps/ai-service/models/loader.py
    apps/ai-service/evaluation/*
    apps/ai-service/config.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    pass
