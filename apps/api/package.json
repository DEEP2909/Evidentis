{
  "name": "@evidentis/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "tsx src/worker-main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reportsDirectory=../../coverage",
    "test:smoke": "vitest run tests/ci-smoke.test.ts",
    "test:coverage:ci": "vitest run --coverage --coverage.reportsDirectory=../../coverage",
    "test:watch": "vitest",
    "test:isolation": "vitest run src/tests/isolation.test.ts",
    "migrate": "node-pg-migrate --migrations-dir ../../db/migrations",
    "migrate:up": "node-pg-migrate up --migrations-dir ../../db/migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir ../../db/migrations",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.645.0",
    "@aws-sdk/s3-request-presigner": "^3.645.0",
    "@evidentis/shared": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/sdk-trace-node": "^1.26.0",
    "@simplewebauthn/server": "^10.0.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.7.7",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.13.2",
    "clamdjs": "^1.0.2",
    "date-fns": "^3.6.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jose": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "nanoid": "^5.0.7",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.5",
    "otpauth": "^9.3.2",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "razorpay": "^2.9.4",
    "samlify": "^2.8.11",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.16.5",
    "@types/nodemailer": "^6.4.16",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.0",
    "vitest": "^2.1.1"
  }
}
