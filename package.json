{
  "name": "evidentis",
  "version": "1.0.0",
  "private": true,
  "description": "EvidentIS India - Enterprise Legal AI Platform for Indian legal teams",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:full": "concurrently --kill-others-on-fail --names api,web \"npm run dev:api\" \"npm run dev:web:wait\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:web:wait": "node ./scripts/wait-for-port.mjs 127.0.0.1 4000 120 && npm run dev:web",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:isolation": "npm run test:isolation -w apps/api",
    "migrate": "npm run migrate -w apps/api",
    "migrate:up": "npm run migrate:up -w apps/api",
    "migrate:down": "npm run migrate:down -w apps/api",
    "seed": "npm run seed -w apps/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "jsdom": "^25.0.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "cross-spawn": "7.0.5",
    "glob": "11.1.0",
    "minimatch": "9.0.7",
    "tar": "7.5.13"
  },
  "author": "EvidentIS Team",
  "license": "UNLICENSED"
}
