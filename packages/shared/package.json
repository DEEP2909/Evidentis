  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  }
